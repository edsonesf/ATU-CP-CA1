<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CoffeeShopApp.Views.OrderDetailPage"
             Title="Order Details"
             BackgroundColor="#2C1A0E">

    <VerticalStackLayout Padding="16" Spacing="8">

        <Label Text="{Binding OrderNumber}"
               FontSize="20"
               FontAttributes="Bold"
               TextColor="White" />
        <Label Text="{Binding CustomerName}"
               FontSize="15"
               TextColor="#D4A96A" />
        <Label Text="{Binding CreatedAt, StringFormat='{0:dd MMM yyyy, HH:mm}'}"
               FontSize="13"
               TextColor="#888" />

        <BoxView HeightRequest="1" BackgroundColor="#6F3D1F" Margin="0,8" />

        <CollectionView ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="4,6">
                        <Label Text="{Binding Name}"
                               TextColor="White"
                               FontSize="15" />
                        <Label Grid.Column="1"
                               Text="{Binding Quantity, StringFormat='x{0}'}"
                               TextColor="#888"
                               FontSize="14"
                               Margin="8,0" />
                        <Label Grid.Column="2"
                               Text="{Binding Subtotal, StringFormat='€{0:F2}'}"
                               TextColor="#D4A96A"
                               FontSize="14" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <BoxView HeightRequest="1" BackgroundColor="#6F3D1F" Margin="0,8" />

        <Grid ColumnDefinitions="*,Auto">
            <Label Text="Total"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="White" />
            <Label Grid.Column="1"
                   Text="{Binding Total, StringFormat='€{0:F2}'}"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="White" />
        </Grid>

    </VerticalStackLayout>

</ContentPage>
